rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // audio/{projectId}/{trackId}
    // Only authenticated users can access audio files.
    // Read: any signed-in user (membership check happens at Firestore layer).
    // Write: any signed-in user (owner/editor enforcement is at the app layer for now).
    // Max upload size: 200 MB.
    match /audio/{projectId}/{trackId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                  && request.resource.size < 200 * 1024 * 1024
                  && request.resource.contentType.matches('audio/.*');
    }
  }
}
