rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function currentUserId() {
      return request.auth.uid;
    }

    // The app keys user documents by email when available, falling back to UID.
    // getUserKey() in FirebaseStorage.ts: auth.currentUser.email || auth.currentUser.uid
    function currentUserKey() {
      return request.auth.token.email != null
        ? request.auth.token.email
        : request.auth.uid;
    }

    function isMember(projectId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/projects/$(projectId)/members/$(currentUserKey()));
    }

    function isOwner(projectId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId
          in [currentUserKey(), currentUserId()];
    }

    function canEdit(projectId) {
      return isMember(projectId) &&
        get(/databases/$(database)/documents/projects/$(projectId)/members/$(currentUserKey())).data.role
          in ['owner', 'editor'];
    }

    function validSongData(data) {
      return data.keys().hasAll(['name', 'tracks', 'comments', 'tempo', 'updatedAt']) &&
             data.tempo is number &&
             data.updatedAt is number &&
             data.tracks is list &&
             data.comments is list;
    }

    // User profiles — any authenticated user can read; users own their profile
    // doc keyed by email (or uid as fallback)
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
        (currentUserId() == userId || currentUserKey() == userId);
    }

    // Projects
    match /projects/{projectId} {
      allow read: if isAuthenticated() && (
        resource.data.ownerId == currentUserKey() ||
        isMember(projectId)
      );
      allow create: if isAuthenticated();
      allow update: if isOwner(projectId);
      allow delete: if isOwner(projectId);

      // Project members — keyed by email (or uid as fallback)
      match /members/{memberId} {
        allow read: if isMember(projectId);
        // Owner manages members; invited users can write their own membership doc on accept
        allow create: if isOwner(projectId) ||
          (isAuthenticated() && (currentUserId() == memberId || currentUserKey() == memberId));
        allow update: if isOwner(projectId);
        // Owners can remove others; members can remove themselves
        allow delete: if (isOwner(projectId) && memberId != currentUserKey()) ||
          (isAuthenticated() && (currentUserId() == memberId || currentUserKey() == memberId) && !isOwner(projectId));
      }

      // Songs
      match /songs/{songId} {
        allow read: if isAuthenticated() && (isOwner(projectId) || isMember(projectId));
        allow create: if canEdit(projectId) && validSongData(request.resource.data);
        allow update: if canEdit(projectId) &&
                         validSongData(request.resource.data) &&
                         request.resource.data.updatedAt >= resource.data.updatedAt;
        allow delete: if isOwner(projectId);
      }

      // Invites — owner writes; any authenticated user can read to accept
      match /invites/{inviteId} {
        allow read: if isAuthenticated();
        allow create: if isOwner(projectId);
        allow update: if isAuthenticated() &&
          (resource.data.email == request.auth.token.email || isOwner(projectId));
        allow delete: if isOwner(projectId);
      }
    }

    // Ephemeral presence — users write their own doc, members of the same project can read
    match /presence/{presenceId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == presenceId;
    }

    // Per-user project mirrors for fast listing — keyed by email or uid
    match /userProjects/{userId} {
      match /projects/{projectId} {
        allow read, write: if isAuthenticated() &&
          (currentUserId() == userId || currentUserKey() == userId);
      }
    }
  }
}
